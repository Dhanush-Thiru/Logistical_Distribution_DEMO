    # ─── Plot 4: Supply vs Demand scatter
    fig4, ax = plt.subplots(figsize=(10, 7))
    segment_colors = {
        "🔴 High Demand / Under-supplied": "#e74c3c",
        "🟢 High Demand / Well-supplied":  "#2ecc71",
        "🟡 Low Demand / Over-supplied":   "#f1c40f",
