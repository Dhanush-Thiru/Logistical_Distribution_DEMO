# ── 9. INTERACTIVE PLOTLY DASHBOARD ──────────────────────────
def plot_interactive(agg, alerts_df):
    print("🌐 Building interactive Plotly dashboard…\n")

    # Revenue treemap
    fig_tree = px.treemap(
        agg, path=["Region", "State", "Product"] if "Region" in agg.columns else ["State", "Product"],
        values="Total_Revenue",
        color="Avg_Gap_Pct",
        color_continuous_scale=["green", "yellow", "red"],
        title="💰 Revenue & Supply Gap Treemap (red = more shortage)",
        color_continuous_midpoint=15,
    )
    fig_tree.update_layout(margin=dict(t=50, l=10, r=10, b=10))
    fig_tree.show()

    # Recommended stock grouped bar
    fig_bar = px.bar(
        agg.sort_values("Recommended_Stock", ascending=False).head(40),
        x="State", y="Recommended_Stock", color="Product",
        title="📦 Recommended Stock Allocation by State & Product",
        barmode="group",
        color_discrete_sequence=px.colors.qualitative.Set2,
    )
    fig_bar.update_layout(xaxis_tickangle=-40)
    fig_bar.show()

    # Alerts table
    if len(alerts_df):
        fig_tbl = go.Figure(data=[go.Table(
            header=dict(
                values=["Level", "State", "Product", "Gap%", "Revenue (₹)", "Suggestion"],
                fill_color="#2c3e50", font=dict(color="white", size=11),
                align="left",
            ),
            cells=dict(
                values=[
                    alerts_df["Level"], alerts_df["State"], alerts_df["Product"],
                    alerts_df["Gap_%"].apply(lambda x: f"{x:.1f}%"),
                    alerts_df["Revenue"].apply(lambda x: f"₹{x:,.0f}"),
                    alerts_df["Message"],
                ],
                fill_color=[
                    ["#fdecea" if "CRITICAL" in str(l)
                     else "#fffde7" if "WARNING" in str(l)
                     else "#e8f5e9" if "SAFE" in str(l)
                     else "#e3f2fd" for l in alerts_df["Level"]]
                ] + [["white"] * len(alerts_df)] * 5,
                align="left", font=dict(size=10),
            ),
        )])
        fig_tbl.update_layout(title="🚨 Live Alert Board", height=400)
        fig_tbl.show()

    print("✅ Interactive dashboard rendered.\n")


# ── 10. CONSOLE SUMMARY REPORT ───────────────────────────────
def print_summary(df, agg, alerts_df, improvements_df):
    total_rev  = df["Revenue"].sum()
    total_sold = df["Units_Sold"].sum()
    total_sup  = df["Supply_Available"].sum()
    gap_pct    = ((total_sold - total_sup) / (total_sold + 1)) * 100

    divider = "=" * 65

    print(f"\n{divider}")
    print("  📋  SMART LOGISTICS SYSTEM — EXECUTIVE SUMMARY")
    print(divider)
    print(f"  Total Revenue       : ₹{total_rev:>14,.2f}")
    print(f"  Total Units Sold    : {total_sold:>14,}")
    print(f"  Total Supply        : {total_sup:>14,}")
    print(f"  Overall Demand Gap  : {gap_pct:>13.1f} %")
    print(f"  States Covered      : {agg['State'].nunique():>14}")
    print(f"  Products Tracked    : {agg['Product'].nunique():>14}")
    print(divider)

    print("\n  🔴  CRITICAL ALERTS (Immediate Action Required)")
    print("  " + "-" * 60)
    crit = alerts_df[alerts_df["Level"].str.contains("CRITICAL")] if len(alerts_df) else pd.DataFrame()
    if len(crit):
        for _, r in crit.iterrows():
            print(f"  • {r['State']} | {r['Product']:20s} | Gap: {r['Gap_%']:5.1f}%")
            print(f"    → {r['Message']}")
    else:
        print("  ✅ No critical alerts — supply is adequate.")

    print("\n  🟡  WARNINGS")
    print("  " + "-" * 60)
    warn = alerts_df[alerts_df["Level"].str.contains("WARNING")] if len(alerts_df) else pd.DataFrame()
    if len(warn):
        for _, r in warn.head(5).iterrows():
            print(f"  • {r['State']} | {r['Product']:20s} | Gap: {r['Gap_%']:5.1f}%")
    else:
        print("  ✅ No warnings.")

    print("\n  ✅  SAFE (Well-supplied, No Action Needed)")
    print("  " + "-" * 60)
    safe = alerts_df[alerts_df["Level"].str.contains("SAFE")] if len(alerts_df) else pd.DataFrame()
    if len(safe):
        for _, r in safe.head(8).iterrows():
            print(f"  • {r['State']} | {r['Product']:20s} | Gap: {r['Gap_%']:5.1f}%  ✅")
    else:
        print("  (No safe entries found — check thresholds.)")

    print("\n  🏆  TOP 5 STATES BY REVENUE")
    print("  " + "-" * 60)
    top5 = agg.groupby("State")["Total_Revenue"].sum().nlargest(5)
    for state, rev in top5.items():
        print(f"  {state:<20s}  ₹{rev:>12,.0f}")

    print("\n  🔧  AREAS OF IMPROVEMENT")
    print("  " + "-" * 60)
    if len(improvements_df):
        for _, r in improvements_df.head(6).iterrows():
            print(f"  {r['Priority']}  {r['Area']} — {r['Product']}")
            print(f"    → {r['Suggestion']}")
    else:
        print("  ✅ Distribution looks balanced.")

    print(f"\n{divider}\n")


# ── 11. EXPORT TABLES ────────────────────────────────────────
def export_results(agg, alerts_df, improvements_df):
    agg.to_csv("allocation_report.csv", index=False)
    alerts_df.to_csv("alerts.csv", index=False) if len(alerts_df) else None
    improvements_df.to_csv("improvements.csv", index=False) if len(improvements_df) else None

    try:
        with pd.ExcelWriter("logistics_report.xlsx", engine="openpyxl") as writer:
            agg.to_excel(writer, sheet_name="Allocation", index=False)
            if len(alerts_df):
                alerts_df.to_excel(writer, sheet_name="Alerts", index=False)
            if len(improvements_df):
                improvements_df.to_excel(writer, sheet_name="Improvements", index=False)
        print("📁 Excel report saved → logistics_report.xlsx")
    except Exception as e:
        print(f"⚠️  Excel export skipped ({e}). CSVs saved instead.")

    print("📁 CSV files saved → allocation_report.csv, alerts.csv, improvements.csv")


if __name__ == "__main__":

    USE_SAMPLE = True

    df_raw = load_data(use_sample=USE_SAMPLE)

    # ── STEP 2: Preprocess
    df = preprocess(df_raw)

    # ── STEP 3: AI Analysis
    agg = run_ai_analysis(df)

    # ── STEP 4: Alerts
    alerts_df = generate_alerts(df, agg)

    # ── STEP 5: Improvements
    improvements_df = generate_improvements(agg, alerts_df)

    # ── STEP 6: Static matplotlib charts
    plot_dashboard(df, agg, alerts_df, improvements_df)

    # ── STEP 7: Interactive Plotly dashboard
    plot_interactive(agg, alerts_df)

    # ── STEP 8: Console summary
    print_summary(df, agg, alerts_df, improvements_df)

    # ── STEP 9: Export reports
    export_results(agg, alerts_df, improvements_df)

    print("\n Done Check the files panel on the left for all saved outputs.")
