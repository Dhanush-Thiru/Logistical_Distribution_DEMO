# ── 2. SAMPLE DATA GENERATOR (if you don't have a CSV) ──────
def generate_sample_data():
    """
    Generates realistic Indian textile/garment sales data across states.
    Veshti is high in South India, Salwar Kameez in North, etc.
    """
    np.random.seed(42)

    states = {
        # state: (region, demand_multiplier_dict)
        "Tamil Nadu":      ("South", {"Veshti": 3.5, "Saree": 2.8, "Dhoti": 2.0, "Salwar Kameez": 0.6, "Kurta": 1.2}),
        "Kerala":          ("South", {"Veshti": 3.2, "Saree": 2.6, "Dhoti": 1.8, "Salwar Kameez": 0.5, "Kurta": 1.0}),
        "Karnataka":       ("South", {"Veshti": 2.4, "Saree": 2.5, "Dhoti": 1.5, "Salwar Kameez": 0.9, "Kurta": 1.5}),
        "Andhra Pradesh":  ("South", {"Veshti": 2.8, "Saree": 2.7, "Dhoti": 1.6, "Salwar Kameez": 0.7, "Kurta": 1.1}),
        "Telangana":       ("South", {"Veshti": 2.2, "Saree": 2.4, "Dhoti": 1.4, "Salwar Kameez": 0.8, "Kurta": 1.3}),
        "Uttar Pradesh":   ("North", {"Veshti": 0.3, "Saree": 1.4, "Dhoti": 0.8, "Salwar Kameez": 3.2, "Kurta": 2.8}),
        "Rajasthan":       ("North", {"Veshti": 0.2, "Saree": 1.2, "Dhoti": 0.6, "Salwar Kameez": 2.9, "Kurta": 2.5}),
        "Punjab":          ("North", {"Veshti": 0.1, "Saree": 0.9, "Dhoti": 0.4, "Salwar Kameez": 3.5, "Kurta": 2.2}),
        "Haryana":         ("North", {"Veshti": 0.2, "Saree": 1.0, "Dhoti": 0.5, "Salwar Kameez": 3.0, "Kurta": 2.0}),
        "Delhi":           ("North", {"Veshti": 0.4, "Saree": 1.5, "Dhoti": 0.7, "Salwar Kameez": 2.8, "Kurta": 2.6}),
        "Maharashtra":     ("West",  {"Veshti": 1.0, "Saree": 2.0, "Dhoti": 1.0, "Salwar Kameez": 1.5, "Kurta": 1.8}),
        "Gujarat":         ("West",  {"Veshti": 0.8, "Saree": 1.8, "Dhoti": 0.9, "Salwar Kameez": 1.6, "Kurta": 1.7}),
        "West Bengal":     ("East",  {"Veshti": 1.2, "Saree": 2.8, "Dhoti": 1.5, "Salwar Kameez": 1.4, "Kurta": 1.6}),
        "Odisha":          ("East",  {"Veshti": 1.5, "Saree": 2.6, "Dhoti": 1.8, "Salwar Kameez": 0.9, "Kurta": 1.2}),
        "Assam":           ("East",  {"Veshti": 0.9, "Saree": 2.3, "Dhoti": 1.2, "Salwar Kameez": 1.2, "Kurta": 1.1}),
    }

    products   = ["Veshti", "Saree", "Dhoti", "Salwar Kameez", "Kurta"]
    months     = ["Jan", "Feb", "Mar", "Apr", "May", "Jun",
                  "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"]
    base_price = {"Veshti": 450, "Saree": 800, "Dhoti": 350,
                  "Salwar Kameez": 650, "Kurta": 500}

    rows = []
    for state, (region, multipliers) in states.items():
        for product in products:
            for month in months:
                mult    = multipliers[product]
                base    = 1000
                # seasonal bump
                festive = 1.5 if month in ["Oct", "Nov"] else (1.2 if month in ["Jan","Apr"] else 1.0)
                units_sold   = max(0, int(np.random.normal(base * mult * festive, base * mult * 0.15)))
                supply_avail = max(0, int(np.random.normal(base * mult * festive * 0.85, base * mult * 0.2)))
                price   = base_price[product] * np.random.uniform(0.92, 1.08)
                rows.append({
                    "State": state, "Region": region, "Product": product,
                    "Month": month, "Units_Sold": units_sold,
                    "Supply_Available": supply_avail,
                    "Unit_Price": round(price, 2),
                    "Revenue": round(units_sold * price, 2),
                    "Demand_Score": round(mult * festive, 3)
                })

    df = pd.DataFrame(rows)
    df.to_csv("sample_sales_data.csv", index=False)
    print("📄 sample_sales_data.csv generated with", len(df), "rows.")
    print("   Columns:", list(df.columns))
    return df


