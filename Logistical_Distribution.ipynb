# ── 4. DATA VALIDATION & PREPROCESSING ──────────────────────
def preprocess(df):
    df = df.copy()
    df.columns = [c.strip().replace(" ", "_") for c in df.columns]

    required = ["State", "Product", "Units_Sold", "Supply_Available", "Revenue"]
    missing  = [c for c in required if c not in df.columns]
    if missing:
        raise ValueError(f"❌ Missing required columns: {missing}\n"
                         f"   Your CSV has: {list(df.columns)}")

    df["Units_Sold"]       = pd.to_numeric(df["Units_Sold"],       errors="coerce").fillna(0)
    df["Supply_Available"] = pd.to_numeric(df["Supply_Available"], errors="coerce").fillna(0)
    df["Revenue"]          = pd.to_numeric(df["Revenue"],          errors="coerce").fillna(0)

    # Demand gap: positive = demand exceeds supply (shortage)
    df["Demand_Gap"]       = df["Units_Sold"] - df["Supply_Available"]
    df["Gap_Pct"]          = (df["Demand_Gap"] / (df["Units_Sold"] + 1)) * 100
    df["Shortage_Flag"]    = df["Demand_Gap"] > 0

    print("✅ Data preprocessed. Shape:", df.shape)
    return df


# ── 5. AI DEMAND ANALYSIS (scikit-learn) ────────────────────
def run_ai_analysis(df):
    print("\n🤖 Running AI Demand Analysis…")

    # ── 5a. Aggregate per State-Product
    agg = (df.groupby(["State", "Product"])
             .agg(Total_Sold    = ("Units_Sold",       "sum"),
                  Total_Supply  = ("Supply_Available", "sum"),
                  Total_Revenue = ("Revenue",          "sum"),
                  Avg_Gap_Pct   = ("Gap_Pct",          "mean"))
             .reset_index())

    agg["Demand_Index"]  = (agg["Total_Sold"] /
                            (agg.groupby("Product")["Total_Sold"]
                                .transform("max") + 1)) * 100
    agg["Supply_Ratio"]  = agg["Total_Supply"] / (agg["Total_Sold"] + 1)

    # ── 5b. K-Means clustering to segment state-products
    features   = ["Demand_Index", "Supply_Ratio", "Avg_Gap_Pct"]
    X          = agg[features].fillna(0)
    scaler     = StandardScaler()
    X_scaled   = scaler.fit_transform(X)

    kmeans = KMeans(n_clusters=4, random_state=42, n_init=10)
    agg["Cluster"] = kmeans.fit_predict(X_scaled)

    cluster_labels = {}
    for c in range(4):
        sub  = agg[agg["Cluster"] == c]
        di   = sub["Demand_Index"].mean()
        sr   = sub["Supply_Ratio"].mean()
        gp   = sub["Avg_Gap_Pct"].mean()
        if di > 60 and gp > 10:
            cluster_labels[c] = "🔴 High Demand / Under-supplied"
        elif di > 60 and sr >= 1.0:
            cluster_labels[c] = "🟢 High Demand / Well-supplied"
        elif di <= 40 and sr >= 1.0:
            cluster_labels[c] = "🟡 Low Demand / Over-supplied"
        else:
            cluster_labels[c] = "🔵 Moderate Demand / Balanced"

    agg["Segment"] = agg["Cluster"].map(cluster_labels)

    # ── 5c. RandomForest to predict demand score per state-product
    if "Demand_Score" in df.columns:
        rf_data = (df.groupby(["State", "Product"])
                     .agg(Demand_Score    = ("Demand_Score", "mean"),
                          Shortage_Count  = ("Shortage_Flag", "sum"),
                          Months          = ("Units_Sold", "count"))
                     .reset_index())
        agg = agg.merge(rf_data, on=["State", "Product"], how="left")
    else:
        # Proxy: normalised demand index
        agg["Demand_Score"] = agg["Demand_Index"] / 100

    # ── 5d. Smart allocation: distribute budget proportionally by demand
    total_supply_per_product = (df.groupby("Product")["Supply_Available"]
                                  .sum().to_dict())
    agg["Recommended_Stock"] = 0.0
    for product, grp_idx in agg.groupby("Product").groups.items():
        grp    = agg.loc[grp_idx]
        total  = grp["Demand_Index"].sum()
        budget = total_supply_per_product.get(product, grp["Total_Sold"].sum() * 0.9)
        shares = (grp["Demand_Index"] / (total + 1e-9)) * budget
        agg.loc[grp_idx, "Recommended_Stock"] = shares.round(0)

    agg["Stock_vs_Current"] = agg["Recommended_Stock"] - agg["Total_Supply"]

    print("✅ AI Analysis complete.")
    return agg


# ── 6. ALERT ENGINE ──────────────────────────────────────────
ALERT_THRESHOLDS = {
    "CRITICAL": 30,   # gap% above this → critical alert
    "WARNING":  10,   # gap% above this → warning
}

def generate_alerts(df, agg):
    alerts = []
    for _, row in agg.iterrows():
        gap   = row["Avg_Gap_Pct"]
        state = row["State"]
        prod  = row["Product"]
        rev   = row["Total_Revenue"]
        rec   = row["Recommended_Stock"]
        curr  = row["Total_Supply"]

        if gap > ALERT_THRESHOLDS["CRITICAL"]:
            level = "🔴 CRITICAL"
            msg   = (f"{state} needs {prod} urgently — "
                     f"{gap:.1f}% demand unmet. "
                     f"Recommend restocking by {rec - curr:,.0f} units.")
        elif gap > ALERT_THRESHOLDS["WARNING"]:
            level = "🟡 WARNING"
            msg   = (f"{state}: {prod} showing {gap:.1f}% supply gap. "
                     f"Consider adding {max(0, rec - curr):,.0f} units.")
        elif row["Supply_Ratio"] > 1.5:
            level = "🔵 INFO"
            msg   = (f"{state} has excess {prod} stock "
                     f"(supply {row['Supply_Ratio']:.1f}× demand). "
                     f"Redirect surplus to high-demand states.")
        else:
            # ✅ SAFE: gap is low and supply is healthy
            level = "✅ SAFE"
            msg   = (f"{state}: {prod} is well-supplied. "
                     f"Gap is only {gap:.1f}% — no action needed.")

        alerts.append({"Level": level, "State": state, "Product": prod,
                        "Gap_%": round(gap, 1), "Revenue": rev, "Message": msg})

    alerts_df = pd.DataFrame(alerts)
    n_crit = alerts_df["Level"].str.contains("CRITICAL").sum()
    n_warn = alerts_df["Level"].str.contains("WARNING").sum()
    n_safe = alerts_df["Level"].str.contains("SAFE").sum()
    print(f"🚨 Alerts — 🔴 {n_crit} Critical  |  🟡 {n_warn} Warning  |  ✅ {n_safe} Safe")
    return alerts_df


# ── 7. AREAS OF IMPROVEMENT ──────────────────────────────────
def generate_improvements(agg, alerts_df):
    improvements = []

    # Critical shortages
    crit = alerts_df[alerts_df["Level"].str.contains("CRITICAL")] if len(alerts_df) else pd.DataFrame()
    if len(crit) > 0:
        top3 = crit.nlargest(3, "Gap_%")
        for _, r in top3.iterrows():
            improvements.append({
                "Priority": "🔴 High",
                "Area": r["State"],
                "Product": r["Product"],
                "Suggestion": f"Increase {r['Product']} allocation by ~{r['Gap_%']:.0f}%. "
                              f"This state contributes ₹{r['Revenue']:,.0f} in revenue."
            })

    # Over-supplied states
    over = agg[agg["Supply_Ratio"] > 1.5]
    for _, r in over.iterrows():
        improvements.append({
            "Priority": "🟡 Medium",
            "Area": r["State"],
            "Product": r["Product"],
            "Suggestion": f"Redirect excess {r['Product']} stock to high-demand regions. "
                          f"Current supply is {r['Supply_Ratio']:.1f}× actual demand."
        })

    # Regional imbalance
    if "Region" in agg.columns:
        region_agg = (agg.groupby(["Region", "Product"])
                        .agg(Avg_Gap = ("Avg_Gap_Pct", "mean"))
                        .reset_index())
        for _, r in region_agg[region_agg["Avg_Gap"] > 15].iterrows():
            improvements.append({
                "Priority": "🟠 Medium-High",
                "Area": f"{r['Region']} region",
                "Product": r["Product"],
                "Suggestion": f"Entire {r['Region']} region has avg {r['Avg_Gap']:.1f}% "
                              f"{r['Product']} shortfall. Review regional warehouse capacity."
            })

    return pd.DataFrame(improvements).drop_duplicates().head(15)


# ── 8. VISUALISATION DASHBOARD ───────────────────────────────
def plot_dashboard(df, agg, alerts_df, improvements_df):
    print("\n📊 Generating Dashboard…\n")

    # ─── Plot 1: Demand heatmap (State × Product)
    pivot = agg.pivot_table(index="State", columns="Product",
                            values="Demand_Index", aggfunc="mean").fillna(0)
    fig1, ax = plt.subplots(figsize=(13, 7))
    sns.heatmap(pivot, annot=True, fmt=".0f", cmap="YlOrRd",
                linewidths=0.5, ax=ax, cbar_kws={"label": "Demand Index (0–100)"})
    ax.set_title("🗺️  Demand Index by State & Product", fontsize=14, fontweight="bold", pad=12)
    ax.set_xlabel("Product", fontsize=11)
    ax.set_ylabel("State", fontsize=11)
    plt.tight_layout()
    plt.savefig("demand_heatmap.png", dpi=130, bbox_inches="tight")
    plt.show()
    print("Saved → demand_heatmap.png\n")

    # ─── Plot 2: Recommended allocation bars per product
    for product in agg["Product"].unique():
        sub = agg[agg["Product"] == product].sort_values("Recommended_Stock", ascending=False)
        fig2, ax = plt.subplots(figsize=(12, 5))
        colors = ["#e74c3c" if g > 20 else "#f39c12" if g > 5 else "#2ecc71"
                  for g in sub["Avg_Gap_Pct"]]
        bars = ax.barh(sub["State"], sub["Recommended_Stock"], color=colors, edgecolor="white")
        ax.bar_label(bars, fmt="%.0f", padding=4, fontsize=9)
        ax.set_title(f"📦  Recommended Stock Allocation — {product}",
                     fontsize=13, fontweight="bold")
        ax.set_xlabel("Recommended Units")
        handles = [mpatches.Patch(color="#e74c3c", label="Critical shortage (>20% gap)"),
                   mpatches.Patch(color="#f39c12", label="Warning (5–20% gap)"),
                   mpatches.Patch(color="#2ecc71", label="Healthy supply")]
        ax.legend(handles=handles, loc="lower right", fontsize=8)
        plt.tight_layout()
        fname = f"allocation_{product.replace(' ', '_')}.png"
        plt.savefig(fname, dpi=130, bbox_inches="tight")
        plt.show()
        print(f"Saved → {fname}")

    # ─── Plot 3: Revenue by State (top 10)
    rev_state = (agg.groupby("State")["Total_Revenue"]
                    .sum().sort_values(ascending=False).head(10))
